# ── Required ─────────────────────────────────────────────────────────────────
# Generate a strong random secret for JWT tokens.
# On Linux/Mac: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string


# ── Email OTP Verification (for registration) ─────────────────────────────────
# Used to send 6-digit verification codes to new users.
# Option A — Gmail (recommended):
#   1. Enable 2-Step Verification on your Gmail account
#   2. Go to Google Account → Security → App Passwords → Generate
#   3. Fill in the values below
# Option B — Any SMTP server: change SMTP_HOST and SMTP_PORT accordingly.
#
# If left blank, OTP emails are skipped and registration works without verification
# (useful for local dev). Set these in production!
SMTP_EMAIL=your@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=NutriTrack
# SMTP_HOST=smtp.gmail.com   # default: smtp.gmail.com
# SMTP_PORT=587              # default: 587 (TLS)


# ── Optional: HuggingFace (only needed for Moondream2 fallback) ───────────────
# Free token at https://huggingface.co/settings/tokens
# NOT needed if you are using Ollama (recommended).
# HF_TOKEN=hf_...

# ── Optional: Ollama server URL (default: http://localhost:11434) ─────────────
# Change this if Ollama is running on a different host or port.
# OLLAMA_URL=http://localhost:11434

# ── Optional: Ollama model override (default: llava-phi3) ───────────────────
# OLLAMA_MODEL=llava-phi3

# ── Optional: Ollama chat model for NutriBot (default: same as OLLAMA_MODEL) ──
# A text-only model is faster for chat (e.g. phi3, llama3.2:1b)
# OLLAMA_CHAT_MODEL=phi3

# ── Optional: Database (default: SQLite for local dev) ───────────────────────
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/nutritrack

# ── Optional: Frontend URL for CORS (needed in production) ───────────────────
# FRONTEND_URL=https://your-app.render.com
